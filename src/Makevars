# src/Makevars — macOS clang header-path conflict fix
#
# With Xcode 16+ (clang 21) + Homebrew, /usr/local/include (Intel Macs) or
# /opt/homebrew/include (Apple Silicon) appears in CPPFLAGS before the SDK's
# libc++ headers.  <cmath> uses #include_next to find libc++'s own math.h,
# but instead picks up the C-only math.h from Homebrew, causing:
#   "<cmath> tried including <math.h> but didn't find libc++'s <math.h> header"
# This package only needs Rcpp + STL, so stripping those paths is safe.
ifeq ($(shell uname -s),Darwin)
  CPPFLAGS := $(filter-out -I/usr/local/include,$(CPPFLAGS))
  CPPFLAGS := $(filter-out -I/opt/homebrew/include,$(CPPFLAGS))
endif
